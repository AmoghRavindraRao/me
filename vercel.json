{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "env": {
    "VITE_CHATBOT_API_URL": "https://chatbot-api.amoghraor.workers.dev",
    "VITE_BLOG_PROXY_URL": "https://blog-proxy.amogh-portfolio.workers.dev",
    "VITE_VIEW_COUNTER_URL": "https://view-counter.amogh-portfolio.workers.dev",
    "VITE_BASE_URL": "https://amoghravindrarao.vercel.app"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    }
  ]
}
